# --- SECURITY ---
# Never commit your connection strings or secrets
local.settings.json

# --- PYTHON ---
# Ignore the virtual environment
.venv/
venv/
env/
# Ignore compiled bytecode (junk files Python creates)
**/__pycache__/
*.py[cod]

# --- AZURE FUNCTIONS ---
# Ignore internal Azure metadata
.python_packages/
bin/
obj/






# --- Terraform ---
# provider binaries/plugins, regenerated by init
.terraform/ 
**/.terraform/*
# Sensitive variable files
*.tfvars
*.tfvars.json
# Local state 
*.tfstate
*.tfstate.*
**/.terraform/*
# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# CLI configuration files
.terraformrc
